rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read:          if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow create:        if isLoggedIn() && isOwner(userId);
      allow update:        if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow delete:        if isAdmin();
    }

    // ── Subjects ──────────────────────────────────────────────
    match /subjects/{subjectId} {
      allow read, write: if isLoggedIn();
    }

    // ── Schedules ─────────────────────────────────────────────
    match /schedules/{scheduleId} {
      allow read:           if isLoggedIn() && isOwner(resource.data.userId);
      allow create:         if isLoggedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isLoggedIn() && isOwner(resource.data.userId);
    }

    // ── Homeworks ─────────────────────────────────────────────
    match /homeworks/{homeworkId} {
      allow read:           if isLoggedIn() && isOwner(resource.data.userId);
      allow create:         if isLoggedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isLoggedIn() && isOwner(resource.data.userId);
    }
  }
}
